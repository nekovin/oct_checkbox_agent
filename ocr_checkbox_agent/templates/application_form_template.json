{
  "name": "Job Application Form",
  "version": "1.0",
  "fields": {
    "employment_status": {
      "type": "checkbox",
      "options": ["Full-time", "Part-time", "Contract", "Internship"],
      "description": "Preferred employment type"
    },
    "availability": {
      "type": "checkbox",
      "options": ["Immediate", "Two weeks notice", "One month notice", "Other"],
      "description": "When can you start?"
    },
    "work_authorization": {
      "type": "checkbox",
      "options": ["US Citizen", "Permanent Resident", "Work Visa", "Need Sponsorship"],
      "description": "Work authorization status"
    },
    "experience_level": {
      "type": "checkbox",
      "options": ["Entry Level", "1-3 years", "4-7 years", "8+ years"],
      "description": "Years of relevant experience"
    },
    "skills": {
      "type": "checkbox",
      "options": ["Python", "Java", "JavaScript", "C++", "SQL", "Machine Learning", "Data Analysis"],
      "description": "Technical skills (Check all that apply)"
    },
    "remote_work": {
      "type": "checkbox",
      "options": ["Yes", "No", "Hybrid"],
      "description": "Open to remote work?"
    }
  },
  "checkbox_regions": {
    "employment_section": {
      "x": 50,
      "y": 80,
      "width": 500,
      "height": 120,
      "description": "Employment preferences"
    },
    "authorization_section": {
      "x": 50,
      "y": 220,
      "width": 500,
      "height": 100,
      "description": "Work authorization"
    },
    "skills_section": {
      "x": 50,
      "y": 340,
      "width": 500,
      "height": 180,
      "description": "Skills and experience"
    }
  }
}